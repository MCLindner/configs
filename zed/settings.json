// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "kagimcp": {
      "command": "uvx",
      "args": ["kagimcp"]
    }
  },
  "disable_ai": false,
  "proxy": "",
  "agent": {
    "tool_permissions": {
      "tools": {
        "mcp:kagimcp:kagi_search_fetch": {
          "default": "allow"
        },
        "mcp:kagimcp:kagi_extract": {
          "default": "allow"
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^find\\s+/home/michael/\\.local/zed\\.app(\\s|$)"
            },
            {
              "pattern": "^head\\b"
            },
            {
              "pattern": "^ls\\s+/home/michael/\\.local/zed\\.app/libexec/(\\s|$)"
            },
            {
              "pattern": "^cut\\b"
            },
            {
              "pattern": "^base64\\b"
            }
          ]
        }
      }
    },
    "default_model": {
      "effort": "xhigh",
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
      "enable_thinking": true
    },
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b-instruct"
    }
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "effort": "medium",
        "model": "opencode/big-pickle"
      },
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "api_url": "http://localhost:11434",
      "model": "qwen2.5-coder:7b-base",
      "prompt_format": "infer",
      "max_output_tokens": 512
    }
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "available_models": [
        {
          "name": "qwen2.5-coder:7b-base",
          "display_name": "Qwen 2.5 Coder 7B (base)",
          "max_tokens": 4096
        },
        {
          "name": "qwen2.5-coder:7b-instruct",
          "display_name": "Qwen 2.5 Coder 7B Instruct",
          "max_tokens": 4096
        }
      ]
    }
  }
}
